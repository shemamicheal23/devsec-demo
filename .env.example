# Copy this file to .env and fill in the values before running the project.
# Never commit your real .env file — it is listed in .gitignore.

# Required: Django secret key. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Set to True only during local development. Must be False in production.
DJANGO_DEBUG=False

# Comma-separated list of allowed hostnames. Example: myapp.com,www.myapp.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Set to True in production to enable HTTPS-only cookies and HSTS.
DJANGO_HTTPS=False

# Comma-separated list of trusted origins for CSRF checks.
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
